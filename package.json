{
  "name": "leviathan-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node -e \"import { readFileSync, writeFileSync } from 'node:fs'; writeFileSync('public/blog-catalog.json', readFileSync('src/blog/catalog.json'));\" && node scripts/generate-og.mjs && tsc -b && vite build && node scripts/inject-blog-meta.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "og:generate": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/katex": "^0.16.8",
    "@vercel/og": "^0.11.1",
    "katex": "^0.18.1",
    "motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "satori": "^0.28.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
